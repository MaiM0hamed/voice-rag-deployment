# Model under test (open-weight, free)
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# Generation settings. Greedy by default so FP16 vs 4-bit differences are
# attributable to quantization rather than sampling randomness.
MAX_NEW_TOKENS=128
DO_SAMPLE=false
TEMPERATURE=0.0

# Timed repetitions per prompt (median reported)
REPEATS=3
WARMUP_TOKENS=16
