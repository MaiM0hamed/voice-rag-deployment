# --- Local LLM (free, no API key) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# --- LiveKit server (only needed for worker.py, not for run_session_demo.py) ---
# Self-host free: https://github.com/livekit/livekit  (or LiveKit Cloud dev tier)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- Real speech: Deepgram (free tier: https://console.deepgram.com) ---
# One key covers BOTH STT (nova-3) and TTS (Aura). Never commit a real key.
# The key must have STT + TTS permissions enabled.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3                  # STT model
DEEPGRAM_TTS_MODEL=aura-2-andromeda-en # TTS voice/model
