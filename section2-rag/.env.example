# ---------- Embeddings ----------
# "huggingface" (default): all-MiniLM-L6-v2 locally. Best quality; needs torch.
# "ollama": nomic-embed-text via Ollama. Use when HF is unreachable or to avoid torch.
EMBEDDING_BACKEND=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---------- Generation (local Ollama, free) ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
LLM_TEMPERATURE=0.0

# ---------- Chunking ----------
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ---------- Retrieval ----------
TOP_K=4
COLLECTION_NAME=electro_pi_docs
USE_HYBRID_SEARCH=true
# Leave unset to use the backend-aware default (0.50 HF / 0.55 Ollama).
# Tune with: python calibrate_threshold.py
# RELEVANCE_THRESHOLD=0.50

# ---------- Logging ----------
# Verbosity for the interactive CLI (app.py). Set INFO to trace retrieval/gate.
LOG_LEVEL=WARNING
