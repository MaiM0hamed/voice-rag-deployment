# Model
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
# Serve the Section 3 4-bit build. Requires a CUDA GPU.
LOAD_IN_4BIT=false
MAX_NEW_TOKENS=256
DEFAULT_TEMPERATURE=0.7

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Capacity: bounds concurrent generations so the accelerator is not oversubscribed.
MAX_CONCURRENT_REQUESTS=4
REQUEST_TIMEOUT_S=120
